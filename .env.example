# ZTB Monitor — environment configuration
# Copy to .env and fill in your values.

# Required — static API key used to obtain a delegate bearer token at login
ZTB_API_KEY=your_api_key_here

# Auto-managed — delegate bearer token returned by the login endpoint.
# The script writes this automatically; you do not need to set it manually.
ZTB_BEARER_TOKEN=

# Optional — defaults shown
ZTB_BASE_URL=https://sbcorp-api.goairgap.com
ZTB_TIMEOUT=30

# Webhook alerts (required when using --output webhook)
ZTB_WEBHOOK_URL=https://hooks.slack.com/services/...
ZTB_WEBHOOK_TYPE=slack          # generic | slack | teams

# Prometheus exporter (required when using --output prometheus)
ZTB_PROMETHEUS_PORT=9090
ZTB_SCRAPE_INTERVAL=60          # seconds between metric collections

# Optional: default gateway ID for resource metrics
ZTB_GATEWAY_ID=
